---
import Layout from '../../components/layout/Layout.astro';
import { CURRENT_FISCAL_YEAR } from '../../config';
import { buildBreadcrumbSchema } from '../../lib/seo';
import { allSalaryPages, formatAmountSpanish } from '../../data/salary-pages-config';
import { calcularSueldoNeto, situacionFamiliarDefecto } from '../../lib/irpf-engine';
import { formatEuros } from '../../lib/format-es';

const title = `Tabla Sueldo Bruto a Neto ${CURRENT_FISCAL_YEAR} España: Todos los Importes`;
const description = `¿Cuánto neto queda de cada salario bruto? Tabla completa con importes mensuales y anuales, IRPF y Seguridad Social desglosados. Datos actualizados ${CURRENT_FISCAL_YEAR}.`;

const monthlyPages = allSalaryPages.filter(p => p.period === 'mes');
const annualPages = allSalaryPages.filter(p => p.period === 'año');

function getNet(annualGross: number): number {
  return calcularSueldoNeto(annualGross, 'MD', situacionFamiliarDefecto, 14).netoMensual;
}

const schemas = [
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Sueldos', url: '/sueldo/' },
  ]),
];
---

<Layout title={title} description={description} schema={schemas}>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <nav class="mb-6 text-sm text-medium-gray">
      <a href="/" class="hover:text-brand">Inicio</a> / <span class="text-charcoal dark:text-gray-200">Sueldos</span>
    </nav>

    <h1 class="mb-6 text-3xl font-bold text-charcoal md:text-4xl dark:text-gray-100">
      Tabla de Sueldo Bruto a Neto en España ({CURRENT_FISCAL_YEAR})
    </h1>

    <p class="mb-8 text-lg text-dark-gray dark:text-gray-300">
      Consulta el sueldo neto aproximado para los importes brutos más buscados en España.
      Cada enlace lleva a una página detallada con desglose por comunidad autónoma y situación familiar.
    </p>

    <section class="mb-10">
      <h2 class="mb-4 text-2xl font-bold text-charcoal dark:text-gray-100">Por salario mensual</h2>
      <div class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-600">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 dark:bg-gray-700">
              <th class="px-4 py-2 text-left font-medium text-gray-500">Bruto/mes</th>
              <th class="px-4 py-2 text-right font-medium text-gray-500">≈ Neto/mes (Madrid)</th>
              <th class="px-4 py-2 text-right font-medium text-gray-500">Bruto/año</th>
              <th class="px-4 py-2 text-left font-medium text-gray-500"></th>
            </tr>
          </thead>
          <tbody>
            {monthlyPages.map(p => (
              <tr class="border-t border-gray-100 dark:border-gray-700">
                <td class="px-4 py-2 font-medium text-charcoal dark:text-gray-100">{formatAmountSpanish(p.amount)} €</td>
                <td class="px-4 py-2 text-right tabular-nums font-medium text-emerald-700 dark:text-emerald-400">{formatEuros(getNet(p.annualGross))}</td>
                <td class="px-4 py-2 text-right tabular-nums text-gray-500">{formatAmountSpanish(p.annualGross)} €</td>
                <td class="px-4 py-2"><a href={`/sueldo/${p.slug}/`} class="text-brand hover:underline">Ver detalle</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="mb-4 text-2xl font-bold text-charcoal dark:text-gray-100">Por salario anual</h2>
      <div class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-600">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 dark:bg-gray-700">
              <th class="px-4 py-2 text-left font-medium text-gray-500">Bruto/año</th>
              <th class="px-4 py-2 text-right font-medium text-gray-500">≈ Neto/mes (Madrid)</th>
              <th class="px-4 py-2 text-right font-medium text-gray-500">≈ Bruto/mes</th>
              <th class="px-4 py-2 text-left font-medium text-gray-500"></th>
            </tr>
          </thead>
          <tbody>
            {annualPages.map(p => (
              <tr class="border-t border-gray-100 dark:border-gray-700">
                <td class="px-4 py-2 font-medium text-charcoal dark:text-gray-100">{formatAmountSpanish(p.amount)} €</td>
                <td class="px-4 py-2 text-right tabular-nums font-medium text-emerald-700 dark:text-emerald-400">{formatEuros(getNet(p.annualGross))}</td>
                <td class="px-4 py-2 text-right tabular-nums text-gray-500">{formatAmountSpanish(Math.round(p.annualGross / 14))} €</td>
                <td class="px-4 py-2"><a href={`/sueldo/${p.slug}/`} class="text-brand hover:underline">Ver detalle</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <div class="text-xs text-medium-gray">
      <p>Cálculo para persona soltera, sin hijos, Madrid, 14 pagas. Ejercicio fiscal {CURRENT_FISCAL_YEAR}.</p>
    </div>
  </div>
</Layout>
