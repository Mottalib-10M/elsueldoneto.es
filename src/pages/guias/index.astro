---
import Layout from '../../components/layout/Layout.astro';
import { CURRENT_FISCAL_YEAR } from '../../config';
import { buildBreadcrumbSchema } from '../../lib/seo';

const title = `Guías Fiscales y Financieras en España ${CURRENT_FISCAL_YEAR}: IRPF y Más`;
const description = `Guías completas sobre fiscalidad y finanzas personales en España ${CURRENT_FISCAL_YEAR}. Aprende sobre IRPF, sueldo neto, régimen Beckham y más con explicaciones claras.`;

const guias = [
  {
    href: '/guias/como-calcular-sueldo-neto/',
    title: 'Cómo calcular el sueldo neto en España',
    summary: 'Del bruto al neto paso a paso: IRPF por tramos, Seguridad Social, mínimo personal y ejemplos prácticos.',
  },
  {
    href: '/guias/regimen-beckham-explicado/',
    title: 'Régimen Beckham: guía completa',
    summary: 'Qué es la Ley Beckham, quién puede acogerse, tributación al 24%, ventajas, inconvenientes y cómo solicitarlo.',
  },
  {
    href: '/guias/jubilacion-espana-edad-pension/',
    title: 'Jubilación en España: edad, pensión y cómo se calcula',
    summary: 'Edad de jubilación, cálculo de la base reguladora, porcentajes por años cotizados, jubilación anticipada, parcial y activa.',
  },
  {
    href: '/guias/cuotas-autonomos-espana/',
    title: 'Cuotas de autónomos en España: tabla por ingresos reales',
    summary: 'Los 15 tramos de cotización del RETA, tarifa plana, gastos deducibles, IRPF y ejemplo práctico para autónomos.',
  },
  {
    href: '/guias/tramos-irpf-espana/',
    title: 'Tramos del IRPF en España: tablas y tipos por comunidad',
    summary: 'Los 6 tramos estatales, cómo se suman los autonómicos, diferencias entre comunidades, tipo efectivo vs. marginal y ejemplo práctico de cálculo.',
  },
  {
    href: '/guias/irpf-por-comunidad-autonoma/',
    title: 'IRPF por Comunidad Autónoma: comparativa completa',
    summary: 'Ranking de las 17 comunidades por sueldo neto, regímenes forales, deducciones autonómicas y ejemplo práctico Madrid vs Cataluña vs Andalucía.',
  },
  {
    href: '/guias/calcular-finiquito-indemnizacion/',
    title: 'Cómo calcular tu finiquito e indemnización',
    summary: 'Diferencia entre finiquito e indemnización, cálculo de vacaciones, pagas extra, despido improcedente y objetivo, tratamiento fiscal y ejemplo práctico.',
  },
];

const schemas = [
  buildBreadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Guías', url: '/guias/' },
  ]),
];
---

<Layout title={title} description={description} schema={schemas}>
  <div class="mx-auto max-w-3xl px-4 py-8">
    <nav class="mb-6 text-sm text-medium-gray">
      <a href="/" class="hover:text-brand">Inicio</a> / <span class="text-charcoal dark:text-gray-200">Guías</span>
    </nav>

    <h1 class="mb-6 text-3xl font-bold text-charcoal md:text-4xl dark:text-gray-100">
      Guías Fiscales y Financieras
    </h1>

    <p class="mb-8 text-lg text-dark-gray dark:text-gray-300">
      Artículos detallados para entender la fiscalidad española y tomar mejores decisiones financieras.
    </p>

    <div class="space-y-6">
      {guias.map(guia => (
        <a href={guia.href} class="block rounded-xl border border-gray-200 bg-white p-6 transition-shadow hover:shadow-md dark:border-gray-700 dark:bg-gray-800">
          <h2 class="mb-2 text-xl font-bold text-charcoal dark:text-gray-100">{guia.title}</h2>
          <p class="text-sm text-dark-gray dark:text-gray-300">{guia.summary}</p>
          <span class="mt-3 inline-block text-sm font-medium text-brand">Leer guía completa →</span>
        </a>
      ))}
    </div>
  </div>
</Layout>
