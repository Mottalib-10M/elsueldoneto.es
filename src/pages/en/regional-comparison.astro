              <td class="px-4 py-2">Balearic Islands</td>
              <td class="px-4 py-2 text-right">-100 to -300 EUR</td>
              <td class="px-4 py-2">Medium-High</td>
            </tr>
            <tr class="border-t border-gray-200 dark:border-gray-700">
              <td class="px-4 py-2">Asturias</td>
              <td class="px-4 py-2 text-right">-100 to -300 EUR</td>
              <td class="px-4 py-2">Medium-High</td>
            </tr>
            <tr class="border-t border-gray-200 dark:border-gray-700">
              <td class="px-4 py-2">Canary Islands</td>
              <td class="px-4 py-2 text-right">-100 to -300 EUR</td>
              <td class="px-4 py-2">Medium-High</td>
            </tr>
            <tr class="border-t border-gray-200 dark:border-gray-700">
              <td class="px-4 py-2">Catalonia</td>
              <td class="px-4 py-2 text-right">-200 to -500 EUR</td>
              <td class="px-4 py-2">High</td>
            </tr>
            <tr class="border-t border-gray-200 dark:border-gray-700">
              <td class="px-4 py-2">Valencian Community</td>
              <td class="px-4 py-2 text-right">-300 to -600 EUR</td>
              <td class="px-4 py-2">High</td>
            </tr>
            <tr class="border-t border-gray-200 dark:border-gray-700">
              <td class="px-4 py-2">Basque Country *</td>
              <td class="px-4 py-2 text-right">Separate system</td>
              <td class="px-4 py-2">Foral regime</td>
            </tr>
            <tr class="border-t border-gray-200 dark:border-gray-700">
              <td class="px-4 py-2">Navarre *</td>
