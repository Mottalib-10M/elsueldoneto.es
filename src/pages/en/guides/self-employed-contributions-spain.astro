              <td class="py-2 pr-4 text-right">€1,166.70</td>
              <td class="py-2 text-right">€275</td>
            </tr>
            <tr class="border-b border-gray-200 dark:border-gray-700">
              <td class="py-2 pr-4">4</td>
              <td class="py-2 pr-4">€1,166.70 - €1,300</td>
              <td class="py-2 pr-4 text-right">€950.98</td>
