              <td class="py-2 text-right">€370</td>
            </tr>
            <tr class="border-b border-gray-200 dark:border-gray-700">
              <td class="py-2 pr-4">13</td>
              <td class="py-2 pr-4">€3,620 - €4,050</td>
              <td class="py-2 pr-4 text-right">€1,274.51</td>
              <td class="py-2 pr-4 text-right">€4,050.00</td>
              <td class="py-2 text-right">€390</td>
            </tr>
            <tr class="border-b border-gray-200 dark:border-gray-700">
              <td class="py-2 pr-4">14</td>
              <td class="py-2 pr-4">€4,050 - €6,000</td>
              <td class="py-2 pr-4 text-right">€1,372.55</td>
              <td class="py-2 pr-4 text-right">€4,495.50</td>
              <td class="py-2 text-right">€420</td>
            </tr>
            <tr class="border-b border-gray-200 dark:border-gray-700">
              <td class="py-2 pr-4">15</td>
              <td class="py-2 pr-4">Over €6,000</td>
              <td class="py-2 pr-4 text-right">€1,633.99</td>
              <td class="py-2 pr-4 text-right">€4,495.50</td>
