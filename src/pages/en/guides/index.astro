---
import Layout from '../../../components/layout/Layout.astro';
import { CURRENT_FISCAL_YEAR } from '../../../config';
import { buildBreadcrumbSchema } from '../../../lib/seo';

const title = `Tax and Finance Guides Spain ${CURRENT_FISCAL_YEAR}: IRPF, Salary & More`;
const description = 'IRPF brackets, net salary, self-employed contributions, retirement, severance and Beckham Law explained step by step. All tax guides for Spain in one place.';

const guides = [
  { href: '/en/guides/how-to-calculate-net-salary/', title: 'How to Calculate Net Salary in Spain', summary: 'Step-by-step guide: IRPF brackets, Social Security, personal minimum and practical examples.' },
  { href: '/en/guides/beckham-law-explained/', title: 'Beckham Law: Complete Guide', summary: 'What is the Beckham Law, who qualifies, 24% flat tax, advantages, drawbacks and how to apply.' },
  { href: '/en/guides/retirement-spain-age-pension/', title: 'Retirement in Spain: Age, Pension & Calculation', summary: 'Retirement age, regulatory base calculation, percentages by years contributed, early and partial retirement.' },
  { href: '/en/guides/self-employed-contributions-spain/', title: 'Self-Employed Contributions in Spain', summary: 'The 15 contribution brackets, flat rate, deductible expenses, IRPF and practical example for autónomos.' },
  { href: '/en/guides/income-tax-brackets-spain/', title: 'Income Tax Brackets in Spain: Tables by Region', summary: 'The 6 state brackets, how regional rates are added, differences between communities, effective vs marginal rate.' },
  { href: '/en/guides/irpf-by-autonomous-community/', title: 'IRPF by Autonomous Community: Full Comparison', summary: 'Ranking of all 17 communities by net salary, foral regimes, regional deductions and practical Madrid vs Catalonia example.' },
  { href: '/en/guides/severance-pay-guide/', title: 'How to Calculate Severance Pay in Spain', summary: 'Difference between settlement and severance, holiday pay, bonus payments, unfair dismissal, tax treatment and examples.' },
];

const schemas = [
  buildBreadcrumbSchema([
    { name: 'Home', url: '/en/' },
    { name: 'Guides', url: '/en/guides/' },
  ]),
];
---

<Layout title={title} description={description} schema={schemas} locale="en">
  <div class="mx-auto max-w-3xl px-4 py-8">
    <nav class="mb-6 text-sm text-medium-gray">
      <a href="/en/" class="hover:text-brand">Home</a> / <span class="text-charcoal dark:text-gray-200">Guides</span>
    </nav>

    <h1 class="mb-6 text-3xl font-bold text-charcoal md:text-4xl dark:text-gray-100">
      Tax and Finance Guides
    </h1>

    <p class="mb-8 text-lg text-dark-gray dark:text-gray-300">
      Detailed articles to help you understand Spanish taxation and make better financial decisions.
    </p>

    <div class="space-y-6">
      {guides.map(guide => (
        <a href={guide.href} class="block rounded-xl border border-gray-200 bg-white p-6 transition-shadow hover:shadow-md dark:border-gray-700 dark:bg-gray-800">
          <h2 class="mb-2 text-xl font-bold text-charcoal dark:text-gray-100">{guide.title}</h2>
          <p class="text-sm text-dark-gray dark:text-gray-300">{guide.summary}</p>
          <span class="mt-3 inline-block text-sm font-medium text-brand">Read full guide →</span>
        </a>
      ))}
    </div>
  </div>
</Layout>
