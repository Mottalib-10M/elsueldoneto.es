---
import Layout from '../../components/layout/Layout.astro';
import { SITE_NAME, SITE_URL } from '../../config';
import { buildBreadcrumbSchema } from '../../lib/seo';

const title = 'Embeddable Widget - Net Salary Calculator for Your Website';
const description = 'Add our free Spanish net salary calculator to your website. Copy the code, paste it into your HTML, and give your visitors a useful financial tool.';

const embedCode = `<iframe src="${SITE_URL}/embed/" width="400" height="420" style="border:none;max-width:100%;border-radius:12px;box-shadow:0 1px 3px rgba(0,0,0,.1)" title="Net Salary Calculator Spain - El Sueldo Neto"></iframe>`;

const schemas = [
  buildBreadcrumbSchema([
    { name: 'Home', url: '/en/' },
    { name: 'Widget', url: '/en/widget/' },
  ]),
];
---

<Layout title={title} description={description} schema={schemas} locale="en">
  <div class="mx-auto max-w-4xl px-4 py-8">
    <nav class="mb-6 text-sm text-medium-gray">
      <a href="/en/" class="hover:text-brand">Home</a> / <span class="text-charcoal dark:text-gray-200">Widget</span>
    </nav>

    <h1 class="mb-6 text-3xl font-bold text-charcoal md:text-4xl dark:text-gray-100">
      Embeddable Widget: Net Salary Calculator
    </h1>

    <p class="mb-8 text-dark-gray dark:text-gray-300">
      Add our net salary calculator to your website, blog, or intranet <strong>completely free of charge</strong>. Just copy and paste the HTML snippet below.
    </p>

    <div class="grid gap-8 lg:grid-cols-2">
      <!-- Preview -->
      <div>
        <h2 class="mb-4 text-lg font-semibold text-charcoal dark:text-gray-100">Preview</h2>
        <iframe
          src="/embed/"
          width="400"
          height="420"
          style="border:none;max-width:100%;border-radius:12px;box-shadow:0 1px 3px rgba(0,0,0,.1)"
          title="Net Salary Calculator Spain - El Sueldo Neto"
          loading="lazy"
        ></iframe>
      </div>

      <!-- Embed code -->
      <div>
        <h2 class="mb-4 text-lg font-semibold text-charcoal dark:text-gray-100">Embed code</h2>
        <div class="relative">
          <pre class="overflow-x-auto rounded-lg border border-gray-200 bg-gray-50 p-4 text-xs text-dark-gray dark:border-gray-700 dark:bg-gray-800 dark:text-gray-300"><code id="embed-code">{embedCode}</code></pre>
          <button
            id="copy-btn"
            class="absolute right-2 top-2 rounded-lg bg-brand px-3 py-1.5 text-xs font-semibold text-white transition-colors hover:bg-brand-dark"
          >
            Copy
          </button>
        </div>

        <div class="mt-6 space-y-3">
          <h3 class="text-sm font-semibold text-charcoal dark:text-gray-100">Widget features</h3>
          <ul class="space-y-2 text-sm text-dark-gray dark:text-gray-300">
            <li class="flex items-start gap-2">
              <span class="mt-0.5 text-brand">&#10003;</span>
              <span><strong>100% free</strong> with no registration</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-0.5 text-brand">&#10003;</span>
              <span>Official AEAT and Social Security data</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-0.5 text-brand">&#10003;</span>
              <span><strong>No data sent</strong> to any server &mdash; calculations run in the browser</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-0.5 text-brand">&#10003;</span>
              <span>Responsive &mdash; adapts to any screen size</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-0.5 text-brand">&#10003;</span>
              <span>Automatically updated every fiscal year</span>
            </li>
          </ul>
        </div>

        <p class="mt-6 text-xs text-medium-gray">
          Need customisation? Contact us at <a href="mailto:contacto@elsueldoneto.es" class="text-brand hover:underline">contacto@elsueldoneto.es</a>
        </p>
      </div>
    </div>
  </div>
</Layout>

<script>
  const btn = document.getElementById('copy-btn');
  const code = document.getElementById('embed-code');
  if (btn && code) {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(code.textContent || '');
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      } catch {
        btn.textContent = 'Error';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      }
    });
  }
</script>
