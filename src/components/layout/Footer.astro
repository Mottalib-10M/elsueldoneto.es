---
import { SITE_NAME, CURRENT_FISCAL_YEAR } from '../../config';
import { getFooterSections, t } from '../../i18n';
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
}

const locale: Locale = Astro.props.locale || 'es';
const sections = getFooterSections(locale);
const homeHref = t(locale, 'homeHref');
---

<footer class="border-t border-gray-200 bg-light-gray dark:border-gray-700 dark:bg-gray-900">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <a href={homeHref} class="mb-4 inline-block text-lg font-bold">
          <span class="text-charcoal dark:text-gray-100">{t(locale, 'brandLeft')} </span>
          <span class="text-brand">{t(locale, 'brandRight')}</span>
        </a>
        <p class="text-sm text-medium-gray">
          {t(locale, 'footerDescription')} {CURRENT_FISCAL_YEAR}.
        </p>
      </div>

      {sections.map((section) => (
        <div>
          <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-charcoal dark:text-gray-200">
            {section.heading}
          </h3>
          <ul class="space-y-2">
            {section.items.map(({ href, label }) => (
              <li>
                <a href={href} class="text-sm text-medium-gray transition-colors hover:text-brand">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-10 border-t border-gray-300 pt-6 dark:border-gray-700">
      <p class="text-center text-xs text-medium-gray">
        &copy; {new Date().getFullYear()} {SITE_NAME}. {t(locale, 'footerDisclaimer')}
        {' '}{t(locale, 'sourcesLabel')} <a href="https://www.agenciatributaria.gob.es" class="underline hover:text-brand" target="_blank" rel="noopener">AEAT</a>,
        <a href="https://www.seg-social.es" class="underline hover:text-brand" target="_blank" rel="noopener">{locale === 'es' ? 'Seguridad Social' : 'Social Security'}</a>,
        <a href="https://www.boe.es" class="underline hover:text-brand" target="_blank" rel="noopener">BOE</a>.
      </p>
    </div>
  </div>
</footer>
