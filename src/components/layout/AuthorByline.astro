---
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
  date?: string;
}

const locale = Astro.props.locale || 'es';
const date = Astro.props.date || new Date().toISOString().split('T')[0];
const aboutHref = locale === 'en' ? '/en/about/' : '/sobre-nosotros/';
const byLabel = locale === 'en' ? 'Written by' : 'Escrito por';
const updatedLabel = locale === 'en' ? 'Updated' : 'Actualizado';
---

<div class="mb-6 flex items-center gap-3 text-sm text-medium-gray">
  <img src="/team/mottalib-radif.jpg" alt="Mottalib Radif" class="h-8 w-8 rounded-full object-cover" width="32" height="32" loading="lazy" />
  <span>
    {byLabel} <a href={aboutHref} class="font-medium text-charcoal hover:text-brand dark:text-gray-200">Mottalib Radif</a>
    <span class="mx-1">·</span>
    MBA INSEAD
    <span class="mx-1">·</span>
    {updatedLabel} {date}
  </span>
</div>
