---
import Header from './Header.astro';
import Footer from './Footer.astro';
import { SITE_NAME, SITE_URL, BRAND_COLOR, CONTACT_EMAIL, AUTHOR_NAME, clarityProjectId, bingVerifyCode } from '../../config';
import { buildCanonical, buildOrganizationSchema, buildWebSiteSchema } from '../../lib/seo';
import { getLocaleFromPath, getHreflangUrls, LANG_MAP, OG_LOCALE_MAP } from '../../i18n';
import type { Locale } from '../../i18n/types';
import '../../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  schema?: object | object[];
  locale?: Locale;
}

const {
  title,
  description,
  canonical,
  ogImage = '/og-default.png',
  ogType = 'website',
  noindex = false,
  schema,
  locale: localeProp,
} = Astro.props;

const locale = localeProp || getLocaleFromPath(Astro.url.pathname);
const lang = LANG_MAP[locale];
const ogLocale = OG_LOCALE_MAP[locale];
const alternateOgLocale = locale === 'es' ? OG_LOCALE_MAP.en : OG_LOCALE_MAP.es;

const canonicalUrl = canonical || buildCanonical(Astro.url.pathname);
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${SITE_URL}${ogImage}`;

const pageSchemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const isHomepage = Astro.url.pathname === '/' || Astro.url.pathname === '' || Astro.url.pathname === '/en/' || Astro.url.pathname === '/en';

// Add Organization + WebSite schemas on the homepage
const schemas = isHomepage
  ? [buildOrganizationSchema(locale), buildWebSiteSchema(locale), ...pageSchemas]
  : pageSchemas;

// Hreflang
const hreflang = getHreflangUrls(Astro.url.pathname);

// Skip-to-content label
const skipLabel = locale === 'en' ? 'Skip to content' : 'Ir al contenido';

// Determine page type for Clarity custom tags
const path = Astro.url.pathname;
const isGuide = path.startsWith('/guia') || path.startsWith('/en/guides');
const pageType = isHomepage ? 'home' : isGuide ? 'guide' : 'calculator';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Site Verification (verified via /google974422056b789dc0.html) -->

    {bingVerifyCode && <meta name="msvalidate.01" content={bingVerifyCode} />}

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={AUTHOR_NAME} />
    <link rel="canonical" href={canonicalUrl} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- hreflang -->
    {hreflang && (
      <>
        <link rel="alternate" hreflang="es" href={`${SITE_URL}${hreflang.es}`} />
        <link rel="alternate" hreflang="en" href={`${SITE_URL}${hreflang.en}`} />
        <link rel="alternate" hreflang="x-default" href={`${SITE_URL}${hreflang.es}`} />
      </>
    )}

    <!-- Preconnect to critical origins -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content={BRAND_COLOR} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={alternateOgLocale} />
    <meta property="og:site_name" content={SITE_NAME} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Schema.org -->
    {schemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- Google Analytics (GA4) – replace G-XXXXXXXXXX with your actual Measurement ID -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>

    <!-- Microsoft Clarity (conditional) -->
    {clarityProjectId && (
      <script is:inline define:vars={{ clarityProjectId, pageType, locale }}>
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window,document,"clarity","script",clarityProjectId);
        if(typeof clarity!=='undefined'){
          clarity("set","page_type",pageType);
          clarity("set","locale",locale);
        }
      </script>
    )}
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-brand focus:px-4 focus:py-2 focus:text-white focus:shadow-lg">
      {skipLabel}
    </a>
    <Header locale={locale} />
    <main id="main-content" class="flex-1" role="main">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
