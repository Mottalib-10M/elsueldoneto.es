---
import { SITE_NAME } from '../../config';

const menuSueldo = [
  { href: '/', label: 'Sueldo Neto' },
  { href: '/calculadora-irpf/', label: 'IRPF' },
  { href: '/calculadora-salario-bruto/', label: 'Salario Bruto' },
  { href: '/comparador-comunidades/', label: 'Comparador CCAA' },
  { href: '/calculadora-autonomos/', label: 'Autónomos' },
  { href: '/regimen-beckham-calculadora/', label: 'Régimen Beckham' },
  { href: '/calculadora-tipo-retencion/', label: 'Tipo de Retención' },
  { href: '/calculadora-pagas-extra/', label: 'Pagas Extra' },
  { href: '/calculadora-hora-trabajada/', label: 'Hora Trabajada' },
  { href: '/calculadora-finiquito/', label: 'Finiquito' },
  { href: '/calculadora-paro/', label: 'Paro' },
];

const menuImpuestos = [
  { href: '/calculadora-iva/', label: 'IVA' },
  { href: '/calculadora-herencia/', label: 'Herencia y Sucesiones' },
  { href: '/calculadora-venta-vivienda/', label: 'Venta de Vivienda' },
  { href: '/calculadora-plusvalia-municipal/', label: 'Plusvalía Municipal' },
];

const menuFinanzas = [
  { href: '/calculadora-hipoteca/', label: 'Hipoteca' },
  { href: '/calculadora-jubilacion/', label: 'Jubilación' },
  { href: '/calculadora-prestamo/', label: 'Préstamo' },
  { href: '/calculadora-interes-compuesto/', label: 'Interés Compuesto' },
  { href: '/calculadora-plan-ahorro/', label: 'Plan de Ahorro' },
  { href: '/calculadora-inflacion/', label: 'Inflación' },
];

const dropdowns = [
  { label: 'Sueldo y Empleo', items: menuSueldo },
  { label: 'Impuestos', items: menuImpuestos },
  { label: 'Finanzas', items: menuFinanzas },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-gray-200 bg-white/95 backdrop-blur-sm dark:border-gray-700 dark:bg-gray-900/95">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
    <a href="/" class="flex items-center gap-2 text-lg font-bold tracking-tight">
      <span class="text-charcoal dark:text-gray-100">El Sueldo</span>
      <span class="text-brand">Neto</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 md:flex" aria-label="Navegación principal">
      {dropdowns.map(({ label, items }) => (
        <div class="dropdown-wrapper relative">
          <button
            type="button"
            class:list={[
              'flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium transition-colors',
              items.some(i => i.href === currentPath)
                ? 'bg-brand/10 text-brand'
                : 'text-dark-gray hover:bg-light-gray hover:text-charcoal dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-white',
            ]}
          >
            {label}
            <svg class="h-3.5 w-3.5 opacity-60 transition-transform duration-200 dropdown-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="dropdown-panel invisible absolute left-0 top-full z-50 min-w-[220px] rounded-lg border border-gray-200 bg-white py-2 opacity-0 shadow-lg transition-all duration-150 dark:border-gray-700 dark:bg-gray-800">
            {items.map(({ href, label: itemLabel }) => (
              <a
                href={href}
                class:list={[
                  'block px-4 py-2 text-sm transition-colors',
                  currentPath === href
                    ? 'bg-brand/10 font-medium text-brand'
                    : 'text-gray-700 hover:bg-gray-50 hover:text-charcoal dark:text-gray-300 dark:hover:bg-gray-700 dark:hover:text-white',
                ]}
                aria-current={currentPath === href ? 'page' : undefined}
              >
                {itemLabel}
              </a>
            ))}
          </div>
        </div>
      ))}
      <a
        href="/guias/"
        class:list={[
          'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
          currentPath.startsWith('/guias')
            ? 'bg-brand/10 text-brand'
            : 'text-dark-gray hover:bg-light-gray hover:text-charcoal dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-white',
        ]}
        aria-current={currentPath.startsWith('/guias') ? 'page' : undefined}
      >
        Guías
      </a>
    </nav>

    <!-- Mobile menu toggle -->
    <button
      id="mobile-menu-toggle"
      class="rounded-lg p-2 text-dark-gray hover:bg-light-gray md:hidden dark:text-gray-300 dark:hover:bg-gray-800"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="hidden border-t border-gray-200 bg-white px-4 pb-4 md:hidden dark:border-gray-700 dark:bg-gray-900"
    aria-label="Navegación móvil"
  >
    {dropdowns.map(({ label, items }) => (
      <div class="mobile-section">
        <button
          type="button"
          class="mobile-section-toggle flex w-full items-center justify-between rounded-lg px-3 py-2.5 text-sm font-semibold text-charcoal transition-colors hover:bg-light-gray dark:text-gray-200 dark:hover:bg-gray-800"
        >
          {label}
          <svg class="h-4 w-4 opacity-50 transition-transform duration-200 mobile-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="mobile-section-items hidden pl-2">
          {items.map(({ href, label: itemLabel }) => (
            <a
              href={href}
              class:list={[
                'block rounded-lg px-3 py-2 text-sm transition-colors',
                currentPath === href
                  ? 'bg-brand/10 font-medium text-brand'
                  : 'text-dark-gray hover:bg-light-gray dark:text-gray-300 dark:hover:bg-gray-800',
              ]}
            >
              {itemLabel}
            </a>
          ))}
        </div>
      </div>
    ))}
    <a
      href="/guias/"
      class:list={[
        'block rounded-lg px-3 py-2.5 text-sm font-semibold transition-colors',
        currentPath.startsWith('/guias')
          ? 'bg-brand/10 text-brand'
          : 'text-charcoal hover:bg-light-gray dark:text-gray-200 dark:hover:bg-gray-800',
      ]}
    >
      Guías
    </a>
  </nav>
</header>

<style>
  /* Desktop dropdown: show on hover */
  .dropdown-wrapper:hover .dropdown-panel,
  .dropdown-wrapper:focus-within .dropdown-panel {
    visibility: visible;
    opacity: 1;
  }
  .dropdown-wrapper:hover .dropdown-chevron,
  .dropdown-wrapper:focus-within .dropdown-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('hidden');
    });
  }

  // Mobile section toggles
  document.querySelectorAll('.mobile-section-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const section = btn.closest('.mobile-section');
      if (!section) return;
      const items = section.querySelector('.mobile-section-items');
      const chevron = btn.querySelector('.mobile-chevron');
      if (items) items.classList.toggle('hidden');
      if (chevron) chevron.classList.toggle('rotate-180');
    });
  });
</script>
