---
import { getMenuGroups, t, getAlternateUrl } from '../../i18n';
import type { Locale } from '../../i18n/types';
import { SITE_URL } from '../../config';

interface Props {
  locale?: Locale;
}

const locale: Locale = Astro.props.locale || 'es';
const dropdowns = getMenuGroups(locale);
const guidesLink = t(locale, 'guidesLink');
const guidesHref = t(locale, 'guidesHref');
const homeHref = t(locale, 'homeHref');
const menuLabel = t(locale, 'menuLabel');
const mobileMenuLabel = t(locale, 'mobileMenuLabel');
const openMenu = t(locale, 'openMenu');

const currentPath = Astro.url.pathname;
const switchLocale = locale === 'es' ? 'en' : 'es';
const switchLabel = locale === 'es' ? 'EN' : 'ES';
const switchUrl = getAlternateUrl(currentPath, switchLocale) || (switchLocale === 'en' ? '/en/' : '/');
---

<header class="sticky top-0 z-50 border-b border-gray-200 bg-white/95 backdrop-blur-sm dark:border-gray-700 dark:bg-gray-900/95">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
    <a href={homeHref} class="flex items-center gap-2 text-lg font-bold tracking-tight">
      <span class="text-charcoal dark:text-gray-100">{t(locale, 'brandLeft')}</span>
      <span class="text-brand">{t(locale, 'brandRight')}</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 md:flex" aria-label={menuLabel}>
      {dropdowns.map(({ label, items }) => (
        <div class="dropdown-wrapper relative">
          <button
            type="button"
            class:list={[
              'flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium transition-colors',
              items.some(i => i.href === currentPath)
                ? 'bg-brand/10 text-brand'
                : 'text-dark-gray hover:bg-light-gray hover:text-charcoal dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-white',
            ]}
          >
            {label}
            <svg class="h-3.5 w-3.5 opacity-60 transition-transform duration-200 dropdown-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="dropdown-panel invisible absolute left-0 top-full z-50 min-w-[220px] rounded-lg border border-gray-200 bg-white py-2 opacity-0 shadow-lg transition-all duration-150 dark:border-gray-700 dark:bg-gray-800">
            {items.map(({ href, label: itemLabel }) => (
              <a
                href={href}
                class:list={[
                  'block px-4 py-2 text-sm transition-colors',
                  currentPath === href
                    ? 'bg-brand/10 font-medium text-brand'
                    : 'text-gray-700 hover:bg-gray-50 hover:text-charcoal dark:text-gray-300 dark:hover:bg-gray-700 dark:hover:text-white',
                ]}
                aria-current={currentPath === href ? 'page' : undefined}
              >
                {itemLabel}
              </a>
            ))}
          </div>
        </div>
      ))}
      <a
        href={guidesHref}
        class:list={[
          'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
          currentPath.startsWith('/guias') || currentPath.startsWith('/en/guides')
            ? 'bg-brand/10 text-brand'
            : 'text-dark-gray hover:bg-light-gray hover:text-charcoal dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-white',
        ]}
        aria-current={currentPath.startsWith('/guias') || currentPath.startsWith('/en/guides') ? 'page' : undefined}
      >
        {guidesLink}
      </a>

      <!-- Language switcher -->
      <a
        href={switchUrl}
        class="ml-2 rounded-lg border border-gray-300 px-2.5 py-1.5 text-xs font-semibold text-gray-600 transition-colors hover:border-brand hover:text-brand dark:border-gray-600 dark:text-gray-300 dark:hover:border-brand"
        title={locale === 'es' ? 'Switch to English' : 'Cambiar a Español'}
      >
        {switchLabel}
      </a>
    </nav>

    <!-- Mobile menu toggle -->
    <div class="flex items-center gap-2 md:hidden">
      <a
        href={switchUrl}
        class="rounded-lg border border-gray-300 px-2.5 py-1.5 text-xs font-semibold text-gray-600 transition-colors hover:border-brand hover:text-brand dark:border-gray-600 dark:text-gray-300"
        title={locale === 'es' ? 'Switch to English' : 'Cambiar a Español'}
      >
        {switchLabel}
      </a>
      <button
        id="mobile-menu-toggle"
        class="rounded-lg p-2 text-dark-gray hover:bg-light-gray dark:text-gray-300 dark:hover:bg-gray-800"
        aria-label={openMenu}
        aria-expanded="false"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="hidden border-t border-gray-200 bg-white px-4 pb-4 md:hidden dark:border-gray-700 dark:bg-gray-900"
    aria-label={mobileMenuLabel}
  >
    {dropdowns.map(({ label, items }) => (
      <div class="mobile-section">
        <button
          type="button"
          class="mobile-section-toggle flex w-full items-center justify-between rounded-lg px-3 py-2.5 text-sm font-semibold text-charcoal transition-colors hover:bg-light-gray dark:text-gray-200 dark:hover:bg-gray-800"
        >
          {label}
          <svg class="h-4 w-4 opacity-50 transition-transform duration-200 mobile-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="mobile-section-items hidden pl-2">
          {items.map(({ href, label: itemLabel }) => (
            <a
              href={href}
              class:list={[
                'block rounded-lg px-3 py-2 text-sm transition-colors',
                currentPath === href
                  ? 'bg-brand/10 font-medium text-brand'
                  : 'text-dark-gray hover:bg-light-gray dark:text-gray-300 dark:hover:bg-gray-800',
              ]}
            >
              {itemLabel}
            </a>
          ))}
        </div>
      </div>
    ))}
    <a
      href={guidesHref}
      class:list={[
        'block rounded-lg px-3 py-2.5 text-sm font-semibold transition-colors',
        currentPath.startsWith('/guias') || currentPath.startsWith('/en/guides')
          ? 'bg-brand/10 text-brand'
          : 'text-charcoal hover:bg-light-gray dark:text-gray-200 dark:hover:bg-gray-800',
      ]}
    >
      {guidesLink}
    </a>
  </nav>
</header>

<style>
  /* Desktop dropdown: show on hover */
  .dropdown-wrapper:hover .dropdown-panel,
  .dropdown-wrapper:focus-within .dropdown-panel {
    visibility: visible;
    opacity: 1;
  }
  .dropdown-wrapper:hover .dropdown-chevron,
  .dropdown-wrapper:focus-within .dropdown-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('hidden');
    });
  }

  // Mobile section toggles
  document.querySelectorAll('.mobile-section-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const section = btn.closest('.mobile-section');
      if (!section) return;
      const items = section.querySelector('.mobile-section-items');
      const chevron = btn.querySelector('.mobile-chevron');
      if (items) items.classList.toggle('hidden');
      if (chevron) chevron.classList.toggle('rotate-180');
    });
  });
</script>
